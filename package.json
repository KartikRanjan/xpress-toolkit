{
    "name": "express-toolkit",
    "version": "1.0.0",
    "description": "A comprehensive utility package for Express applications",
    "type": "module",
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.js",
    "types": "./dist/esm/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/esm/index.d.ts",
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js"
        },
        "./swagger": {
            "types": "./dist/esm/swagger/index.d.ts",
            "import": "./dist/esm/swagger/index.js",
            "require": "./dist/cjs/swagger/index.js"
        },
        "./types/express": {
            "types": "./src/types/express.d.ts"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "clean": "rm -rf dist",
        "build": "npm run clean && tsc && tsc -p tsconfig.cjs.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
        "prepublishOnly": "npm run lint && npm run test && npm run build",
        "test": "vitest run",
        "test:watch": "vitest",
        "demo": "tsx examples/swagger-demo.ts",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write ."
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE",
        "src/types/express.d.ts"
    ],
    "keywords": [
        "express",
        "toolkit",
        "middleware",
        "validation",
        "zod",
        "swagger",
        "openapi",
        "typescript"
    ],
    "author": "Kartik <kartikranjan.work@gmail.com>",
    "license": "MIT",
    "dependencies": {
        "pino": "^9.0.0"
    },
    "peerDependencies": {
        "express": "^4.18 || ^5.0.0",
        "zod": "^3.0.0"
    },
    "optionalPeerDependencies": {
        "swagger-ui-express": "^5.0.0",
        "@asteasolutions/zod-to-openapi": "^7.0.0"
    },
    "devDependencies": {
        "@asteasolutions/zod-to-openapi": "^7.0.0",
        "@eslint/js": "^10.0.1",
        "@types/express": "^4.17.21",
        "@types/node": "^20.0.0",
        "@types/supertest": "^6.0.2",
        "@types/swagger-ui-express": "^4.1.6",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "express": "^4.18.2",
        "globals": "^17.4.0",
        "pino-pretty": "^11.0.0",
        "prettier": "^3.8.1",
        "supertest": "^6.3.4",
        "swagger-ui-express": "^5.0.0",
        "tsx": "^4.7.1",
        "typescript": "^5.0.0",
        "typescript-eslint": "^8.57.1",
        "vitest": "^1.3.1",
        "zod": "^3.22.4"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/KartikRanjan/express-toolkit.git"
    }
}